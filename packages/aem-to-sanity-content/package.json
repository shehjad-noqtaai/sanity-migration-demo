{
  "name": "aem-to-sanity-content",
  "version": "0.0.0",
  "description": "Three flat scripts to migrate AEM content (.infinity.json) into Sanity: extract → transform → import.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "probe:media-library": "tsx ../../scripts/probe-media-library.ts"
  },
  "bin": {
    "aem-extract": "./dist/extract.js",
    "aem-transform": "./dist/transform.js",
    "aem-assets": "./dist/assets.js",
    "aem-import": "./dist/import.js"
  },
  "dependencies": {
    "@portabletext/block-tools": "^5.1.1",
    "@portabletext/schema": "^2.1.1",
    "@types/jsdom": "^28.0.1",
    "aem-to-sanity-core": "workspace:*",
    "dotenv": "^16.4.5",
    "jsdom": "^29.0.2"
  },
  "devDependencies": {
    "@sanity/client": "^7.21.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@sanity/client": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@sanity/client": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
