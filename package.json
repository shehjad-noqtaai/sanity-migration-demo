{
  "name": "aem-to-sanity-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for AEM → Sanity migration tooling (schema generator + content migrator).",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "tsx scripts/ensure-studio-stub.ts",
    "migrate:schema": "turbo run migrate:schema",
    "migrate:content": "turbo run migrate:content",
    "migrate:init": "tsx scripts/migrate-init.ts",
    "migrate:doctor": "tsx scripts/migrate-doctor.ts",
    "typegen": "turbo run typegen",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  }
}
