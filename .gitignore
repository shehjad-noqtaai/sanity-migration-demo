# Dependencies
node_modules/

# Build output & run artifacts
output
*.tsbuildinfo
dist/
.turbo/
.sanity/

# Local-only Hydrogen storefront stub (not part of the migration pipeline)
apps/storefront/

# Local environment (never commit real credentials)
.env
.env.local
.env.*.local

# Project-specific input (contains customer component paths + content roots)
# Operator-authored lists stay untracked; the example's canonical lists are checked in.
aem-component-paths
aem-content-roots
!examples/davids-bridal/aem-component-paths
!examples/davids-bridal/aem-content-roots

# The davids-bridal example's `output/` holds only regenerable pipeline
# state (raw AEM trees, clean transformed docs, asset cache, captured
# fixtures, reports, content-type-registry). Everything under it is ignored.
# Generated Sanity schemas live under `apps/studio/schemas/generated/` now —
# committed so apps/studio builds + validates on bare clone.

