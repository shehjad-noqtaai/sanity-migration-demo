# ---------------------------------------------------------------------------
# AEM source (required for schema + content migration)
# ---------------------------------------------------------------------------

# Which environment to pull from: "author" or "publish"
AEM_ENV=author

# Author environment (used when AEM_ENV=author).
# AEMaaCS URLs look like `https://author-pXXXX-eYYYY.adobeaemcloud.com`.
AEM_AUTHOR_URL=https://author-pXXXX-eYYYY.adobeaemcloud.com

# --- Pick ONE authentication flow (precedence: service-credentials > token > basic) ---
# See docs/running-the-migration.md § 1a-bis for the full walkthrough.

# 1. AEM as a Cloud Service — Service Credentials (recommended for migrations).
#    Download from Cloud Manager → Environment → Developer Console → Integrations
#    → Service Credentials. Supports both OAuth Server-to-Server (modern) and
#    legacy JWT shapes. The migration exchanges these with Adobe IMS at startup.
# AEM_SERVICE_CREDENTIALS_FILE=/absolute/path/to/service-credentials.json
#    Or, for CI, inline the JSON (mutually exclusive with the file path):
# AEM_SERVICE_CREDENTIALS='{"CLIENT_ID":"...","CLIENT_SECRET":"...","SCOPES":["..."], ...}'

# 2. AEM as a Cloud Service — developer (local-development) token.
#    Cloud Manager → Developer Console → Integrations → Get Local Development Token.
#    Short-lived (~24h). Use for quick trials; regenerate if the migration outlives it.
# AEM_TOKEN=

# 3. On-prem / AMS — basic auth (AEMaaCS rejects this).
# AEM_AUTHOR_USERNAME=your-username
# AEM_AUTHOR_PASSWORD=your-password

# Publish environment (used when AEM_ENV=publish)
# AEM_PUBLISH_URL=https://publish-pXXXX-eYYYY.adobeaemcloud.com
# AEM_PUBLISH_USERNAME=your-username
# AEM_PUBLISH_PASSWORD=your-password

# Optional AEM overrides (defaults shown)
# AEM_COMPONENT_PATHS_FILE=./aem-component-paths
# AEM_COMPONENT_EXCEPTIONS_FILE=./aem-component-exceptions
# AEM_COMPONENT_CONTAINERS_FILE=./aem-component-containers.json
# AEM_COMPONENT_HINTS_FILE=./aem-component-hints.json
# AEM_PAGE_COMPONENTS_FILE=./aem-page-components.json
# AEM_CONTENT_ROOTS_FILE=./aem-content-roots
# AEM_TAG_ROOTS_FILE=./aem-tag-roots
# OUTPUT_DIR=./output
# CONCURRENCY=4

# Strip a path prefix from JCR paths when generating Sanity document `_id`s.
# Without this, `/content/<your-site>/<locale>/foo/bar` becomes
# `content-<your-site>-<locale>-foo-bar`. With it set to the site/locale base,
# the id becomes simply `foo-bar`. Typical value matches the `@base` line in
# `aem-content-roots`. Multiple prefixes allowed comma-separated; longest
# match wins. WARNING: changing this between runs orphans previously imported
# docs (new ids != old ids). Set once, leave alone — or run an
# unpublishDocuments pass on the old id space before changing.
# MIGRATION_DOC_ID_PREFIX_STRIP=/content/<your-site>/<locale>

# Verbose logging — same effect as passing `--verbose` to `migrate:schema`.
# At debug level the AEM fetcher logs every GET (plus Sling .N.json fallbacks),
# which is handy for diagnosing 404/auth issues without re-running.
# AEM_VERBOSE=true

# Treat per-component 401/403 as ACL skips (keep going) rather than aborting
# the whole batch. Circuit breaker still aborts on N consecutive auth failures
# with zero successes — that signals credentials-wide failure, not per-path ACL.
# AEM_CONTINUE_ON_AUTH=true

# Where aem-to-sanity-schema emits generated schema .ts files (component schemas
# + page.ts + pageBuilder.ts + index.ts barrel). When unset, defaults to
# {OUTPUT_DIR}/schemas. Point this at a Sanity Studio's schema directory if you
# want generated schemas to land next to the app that consumes them.
# SCHEMAS_OUT_DIR=../../apps/studio/schemas/generated

# ---------------------------------------------------------------------------
# Sanity destination (required for content migration writes + studio)
# ---------------------------------------------------------------------------

SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
# Project robot token (sanity.io/manage → Project → API → Tokens, role: Editor or higher)
# is enough for `aem-import`. For `aem-assets`, newer Media Library API versions reject
# project-scoped robot tokens with `401 SIO-401-ANF "Session not found"` — when that
# happens, paste a personal auth token here instead. See docs/running-the-migration.md
# § 4c-bis for the two ways to generate one (`sanity login` + `sanity debug --secrets`,
# or sanity.io/manage → user menu → Personal access tokens).
SANITY_TOKEN=your-write-token
# Optional; defaults to 2024-01-01
# SANITY_API_VERSION=2024-01-01

# ---------------------------------------------------------------------------
# aem-assets — Media Library (org-scoped assets, NOT dataset Content Lake)
# Required when MIGRATION_DRY_RUN=false.
# ---------------------------------------------------------------------------

# Org-level Media Library id (must belong to the same org as SANITY_PROJECT_ID).
# sanity.io/manage → your org → Media Library → copy the id from the URL.
SANITY_MEDIA_LIBRARY_ID=ml-xxxxxxxxxxxx

# Personal authorization token used for the Media Library → dataset link
# step (phase 3). The `/assets/media-library-link` endpoint rejects project
# robot tokens with `401 Invalid non-global session` — you need a token tied
# to a user who can read/write both the Media Library and the project.
# Two ways to generate one (full walkthrough in docs/running-the-migration.md § 4c-bis):
#   A) sanity login                  # opens browser, authenticates as your user
#      sanity debug --secrets        # prints the live auth token
#   B) sanity.io/manage → user menu  # → User settings → Personal access tokens →
#                                    # Add API token. Stable + long-lived.
# If unset, falls back to SANITY_TOKEN. Tip: if SANITY_TOKEN is already a
# personal token, you don't need to set this separately.
# SANITY_ML_LINK_TOKEN=sk...

# Link-only mode — same effect as passing `--link-only` to aem-assets. Skips
# phases 1 + 2 (download from AEM, upload to ML) and relies on phase 0 to
# find assets already in the Media Library. Intended for re-runs and for
# iterating on link / rewrite logic without re-hitting AEM.
# MIGRATION_LINK_ONLY=true

# aem-assets parallelism — number of workers across phases 0 (ML dedup),
# 1 (AEM download), 2 (ML upload), 3 (dataset link). Default 4. Raise for
# faster runs if AEM + Sanity tolerate it; lower if rate-limited.
# ASSET_CONCURRENCY=4

# Discard drafts on import — same effect as passing `--discard-drafts` to
# aem-import. Deletes drafts.{id} alongside each published createOrReplace
# so the Studio shows freshly-imported content rather than a stale draft
# from a prior run. Destroys authored in-progress edits — opt in only when
# re-running migrations on a dataset only this pipeline writes to.
# MIGRATION_DISCARD_DRAFTS=true
