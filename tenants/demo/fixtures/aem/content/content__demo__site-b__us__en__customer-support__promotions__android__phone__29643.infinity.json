                "jcr:created": "Wed Aug 21 2024 01:02:37 GMT+0530",
                "text": "<table cellpadding=\"1\" cellspacing=\"0\" border=\"1\">\r\n<tbody><tr><th width=\"50%\">Promo period</th>\r\n<td width=\"50%\">May 21, 2026 – TBA</td>\r\n</tr><tr><th>Requirements</th>\r\n<td width=\"50%\">Device Purchase, New Line Activation, Specific Rate Plan</td>\r\n</tr><tr><th>Eligible customers</th>\r\n<td width=\"50%\"><ul>\r\n<li>Postpaid</li>\r\n<li>Site B for Business 1-12 voice lines only (including Business w/ SSN)</li>\r\n<li>Employee (Site B, Non-Site B)</li>\r\n</ul>\r\n</td>\r\n</tr><tr><th>Limits</th>\r\n<td width=\"50%\">4 redemptions per account</td>\r\n</tr><tr><th>Payout</th>\r\n<td width=\"50%\">Recurring Device Credit (RDC)</td>\r\n</tr></tbody></table>\r\n",
