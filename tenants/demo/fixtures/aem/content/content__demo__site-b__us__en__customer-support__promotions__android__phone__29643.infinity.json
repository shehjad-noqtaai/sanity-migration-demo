            "text": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:createdBy": "Epcy.Zacharias1@Site B.com",
              "jcr:lastModifiedBy": "Alkia.Morris@Site B.com",
              "textStyle": "tdds:text-inherit",
              "marginTop": "tdds:mt-0",
              "isAccessRestricted": "false",
              "colorTextSource": "default",
              "jcr:created": "Wed Aug 28 2024 19:18:44 GMT+0000",
              "contentToggle": "false",
              "marginBottom": "tdds:mb-0",
              "text": "<p>This promo&nbsp;follows Site B's standard&nbsp;<a href=\"/content/demo/us/en/customer-support/promotions/promotion-handling/recurring-device-credits-rdc.html\">Recurring Device Credits (RDC) guidelines</a>. For RDC issues, see&nbsp;<a href=\"/content/demo/us/en/customer-support/promotions/promotion-handling/eaa11.html\">Recurring Device Credits (RDC) Promotional Credit Issue Handling</a>.</p>\r\n",
              "jcr:lastModified": "Tue May 19 2026 02:00:16 GMT+0000",
