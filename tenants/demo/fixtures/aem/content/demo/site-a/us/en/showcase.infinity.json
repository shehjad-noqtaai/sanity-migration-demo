              "fontWeight": "thin",
              "as": "p",
              "text": "<p>A: Contact Site A customer service or visit your local store. Bring photos of your event dress or inspiration images, and our team will work with you to create the perfect miniature replica.</p>\n",
              "align": "left",
              "color": "gray800",
              "uppercase": "false",
