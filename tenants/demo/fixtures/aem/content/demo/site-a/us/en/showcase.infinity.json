            "content": {
              "jcr:primaryType": "nt:unstructured",
              "fontFamily": "primary",
              "jcr:lastModifiedBy": "scotton",
              "fontWeight": "thin",
              "as": "p",
              "text": "<p>A: Custom Showcase event dresses typically take 4-6 weeks to complete, depending on the complexity of the design. We recommend ordering well in advance of your event date.</p>\n",
              "align": "left",
              "color": "gray800",
              "uppercase": "false",
              "measure": "md",
              "jcr:lastModified": "Fri Jul 11 2025 14:29:36 GMT+0000",
              "sling:resourceType": "demo-site-a/components/content",
              "textIsRich": "true",
              "display": "block"
            }
          },
