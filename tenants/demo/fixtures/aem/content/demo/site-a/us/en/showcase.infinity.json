        "photo_layout_copy": {
          "jcr:primaryType": "nt:unstructured",
          "removeBottomPadding": "false",
          "jcr:createdBy": "maeschliman",
          "fileReference1": "/content/dam/demo/_generated/event.gif",
          "fileReference2": "/content/dam/demo/_generated/event.gif",
          "fileReference3": "/content/dam/demo/_generated/event.gif",
          "description": "<p>  Get your Showcase doll event-ready with a custom-made outfit. <br />\r\n <br />\r\nMake your big day even more unforgettable with custom Showcase outfits handcrafted to mirror your big-day look. Whether you want your Showcase doll to wear a couture event gown, match your companion dress, or rock a completely original look, our talented team can make it happen, right down to the tiniest detail. <br />\r\n</p>\r\n",
          "imageLink1": "/stores",
          "imageLink3": "/appointments/",
          "imageText2": "<p>Custom showcase clothes are the ultimate keepsake for collectors, fashion lovers, or brides looking to add a little extra personality to their day. Couture and custom event dresses start at $50. Companion dresses and other outfits start at $35. Book an alterations appointment at any David's store to outfit your Showcase!</p>\r\n",
          "jcr:lastModifiedBy": "Catherine.S",
          "removeTopPadding": "false",
          "jcr:created": "Tue Apr 30 2024 19:18:28 GMT+0000",
          "headline2": "Demo Heading B",
