              "fontFamily": "primary",
              "jcr:lastModifiedBy": "scotton",
              "fontWeight": "thin",
              "as": "p",
              "text": "<p>A: While our current collection focuses on event attire, we can create custom Showcase outfits for other special occasions like graduations, proms, or holiday celebrations.</p>\n",
              "align": "left",
              "color": "gray800",
              "uppercase": "false",
