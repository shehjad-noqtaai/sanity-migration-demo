            "content": {
              "jcr:primaryType": "nt:unstructured",
              "fontFamily": "primary",
              "jcr:lastModifiedBy": "scotton",
              "fontWeight": "thin",
              "as": "p",
              "text": "<p>A: Absolutely! We can create matching Showcase companion dresses, flower girl outfits, and even miniature versions of event guest dresses for your entire event party's Showcase collection.</p>\n",
              "align": "left",
              "color": "gray800",
              "uppercase": "false",
              "measure": "md",
              "jcr:lastModified": "Fri Jul 11 2025 14:29:55 GMT+0000",
              "sling:resourceType": "demo-site-a/components/content",
