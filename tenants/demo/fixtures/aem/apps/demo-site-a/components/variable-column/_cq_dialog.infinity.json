                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "type-belowImage": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Below Image Text (Default)",
                            "value": "type_belowImage",
                            "checked": true
                          },
                          "type-onHover": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "On Hover",
                            "value": "type_OnHover",
                            "checked": false
                          }
                        },
                        "granite:data": {
                          "jcr:primaryType": "nt:unstructured",
