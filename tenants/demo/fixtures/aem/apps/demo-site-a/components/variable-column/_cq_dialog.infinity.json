                                      "jcr:primaryType": "nt:unstructured",
                                      "button": {
                                        "jcr:primaryType": "nt:unstructured",
                                        "text": "Button",
                                        "value": "button"
                                      },
                                      "link": {
                                        "jcr:primaryType": "nt:unstructured",
                                        "text": "Link",
                                        "value": "link"
                                      }
                                    }
                                  },
                                  "ctaLabel": {
                                    "jcr:primaryType": "nt:unstructured",
                                    "name": "text",
                                    "fieldLabel": "CTA text",
                                    "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield"
                                  },
                                  "ariaLabel": {
                                    "jcr:primaryType": "nt:unstructured",
                                    "name": "ariaLabel",
                                    "fieldLabel": "Aria label",
                                    "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield"
                                  },
                                  "ctaLink": {
                                    "jcr:primaryType": "nt:unstructured",
                                    "rootPath": "/content",
                                    "name": "link",
                                    "fieldLabel": "CTA link",
                                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield"
                                  }
                                }
                              }
                            }
                          }
                        }
