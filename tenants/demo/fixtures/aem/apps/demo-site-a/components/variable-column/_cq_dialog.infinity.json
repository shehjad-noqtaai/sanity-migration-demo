                              "jcr:primaryType": "nt:unstructured",
                              "vertical": true,
                              "name": "type",
                              "fieldLabel": "CTA type",
                              "sling:resourceType": "granite/ui/components/coral/foundation/form/radiogroup",
                              "items": {
                                "jcr:primaryType": "nt:unstructured",
                                "button": {
                                  "jcr:primaryType": "nt:unstructured",
                                  "text": "Button",
                                  "value": "button",
                                  "checked": true
                                },
                                "link": {
                                  "jcr:primaryType": "nt:unstructured",
                                  "text": "Link",
                                  "value": "link"
