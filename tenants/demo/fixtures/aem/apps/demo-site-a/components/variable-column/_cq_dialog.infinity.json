                            "jcr:primaryType": "nt:unstructured",
                            "col-image": {
                              "jcr:primaryType": "nt:unstructured",
                              "fileReferenceParameter": "./fileReference",
                              "required": true,
                              "useHTML5": false,
                              "mimeTypes": [
                                "image/gif",
                                "image/jpeg",
                                "image/webp",
                                "image/tiff",
                                "image/svg+xml"
                              ],
                              "fileNameParameter": "./fileName",
                              "name": "./image",
                              "class": "cq-droptarget",
                              "disabled": false,
                              "fieldLabel": "Image",
                              "multiple": false,
                              "allowUpload": false,
                              "sling:resourceType": "cq/gui/components/authoring/dialog/fileupload",
                              "autoStart": false
