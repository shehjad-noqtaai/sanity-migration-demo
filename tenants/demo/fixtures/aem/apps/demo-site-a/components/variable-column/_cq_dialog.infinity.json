                          "scroll": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "scroll",
                            "value": "scroll"
                          },
                          "stack": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "stack",
                            "value": "stack"
                          },
                          "grid": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "grid",
                            "value": "grid"
                          },
                          "grid-2-line": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "grid-2-line",
                            "value": "grid-2-line"
