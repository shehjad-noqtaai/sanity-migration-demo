                            "jcr:primaryType": "nt:unstructured",
                            "text": "carousel",
                            "value": "carousel"
                          },
                          "scroll": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "scroll",
                            "value": "scroll"
                          }
                        }
                      },
                      "theme": {
                        "jcr:primaryType": "nt:unstructured",
