                        "fieldLabel": "Theme",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "white": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "White",
                            "value": "white"
                          },
                          "seashell": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Seashell",
                            "value": "seashell"
                          },
                          "seashell-alt": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Seashell-alt",
                            "value": "seashell-alt"
                          },
                          "mocassin": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Mocassin",
                            "value": "mocassin"
                          },
                          "mocassin-alt": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Mocassin-alt",
                            "value": "mocassin-alt"
                          },
                          "claret": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Claret",
                            "value": "claret"
                          },
                          "claret-alt": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Claret-alt",
                            "value": "claret-alt"
                          },
                          "black": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Black",
                            "value": "black"
                          },
                          "black-alt": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Black-alt",
                            "value": "black-alt"
                          }
                        }
                      },
                      "layoutWidthGroup": {
                        "jcr:primaryType": "nt:unstructured",
                        "vertical": true,
                        "name": "./layoutWidth",
                        "fieldLabel": "Layout width",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/radiogroup",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "full-width": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "full-width",
                            "value": "full-width",
                            "checked": true
                          },
                          "in-set": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "in-set",
                            "value": "in-set"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "productTab": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Products",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
