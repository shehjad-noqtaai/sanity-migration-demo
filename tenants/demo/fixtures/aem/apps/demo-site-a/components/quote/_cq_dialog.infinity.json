{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Properties",
  "height": 600,
  "width": 630,
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/container",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "tabs": {
        "jcr:primaryType": "nt:unstructured",
        "maximized": true,
        "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "main": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Properties",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "quote": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./quote",
                        "fieldLabel": "Quote",
                        "sling:resourceType": "cq/gui/components/authoring/dialog/richtext",
                        "useFixedInlineToolbar": true,
                        "rtePlugins": {
                          "jcr:primaryType": "nt:unstructured",
                          "format": {
                            "jcr:primaryType": "nt:unstructured",
                            "features": "*"
                          },
                          "justify": {
                            "jcr:primaryType": "nt:unstructured",
                            "features": "*"
                          },
                          "lists": {
                            "jcr:primaryType": "nt:unstructured",
                            "features": "*"
                          },
                          "links": {
                            "jcr:primaryType": "nt:unstructured",
                            "features": "*"
                          },
                          "misctools": {
                            "jcr:primaryType": "nt:unstructured",
                            "features": "*"
                          }
                        },
                        "htmlRules": {
                          "jcr:primaryType": "nt:unstructured",
                          "links": {
                            "jcr:primaryType": "nt:unstructured",
                            "ensureInternalLinkExt": false
                          }
                        }
                      },
                      "personName": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./personName",
                        "fieldLabel": "Person name",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield"
                      },
                      "align": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./align",
                        "fieldLabel": "Copy position",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "left": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "left",
                            "value": "left"
                          },
                          "right": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "right",
                            "value": "right"
                          },
                          "center": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "center",
                            "value": "center"
                          }
                        }
                      },
                      "size": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./size",
                        "fieldLabel": "Size",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "large": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "large",
                            "value": "large"
                          },
                          "small": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "small",
                            "value": "small"
                          }
                        }
                      },
                      "backgroundColor": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./backgroundColor",
                        "selectDefaultValue": "transparent",
                        "fieldLabel": "Background color",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "datasource": {
                          "jcr:primaryType": "nt:unstructured",
                          "sling:resourceType": "demo-site-a/components/datasources/colortypedatasource"
                        }
                      },
                      "asset-allowed-heading": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Praesent feugiat tellus eget velit fringilla, nec vehicula nisi vulputate.",
                        "level": "2",
                        "sling:resourceType": "granite/ui/components/foundation/heading"
                      },
                      "asset": {
                        "jcr:primaryType": "nt:unstructured",
                        "fileReferenceParameter": "./fileReference",
                        "required": false,
                        "useHTML5": false,
                        "mimeTypes": [
                          "image/gif",
                          "image/jpeg",
                          "image/webp",
                          "image/tiff",
                          "image/svg+xml"
                        ],
                        "fileNameParameter": "./fileName",
                        "name": "./image",
                        "class": "cq-droptarget",
                        "disabled": false,
                        "fieldLabel": "Background image",
                        "multiple": false,
                        "allowUpload": false,
                        "sling:resourceType": "cq/gui/components/authoring/dialog/fileupload",
                        "autoStart": false
                      },
                      "theme": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./theme",
                        "fieldLabel": "Theme",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "image-dark": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Image dark",
                            "value": "image-dark"
                          },
                          "image-light": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Image light",
                            "value": "image-light"
                          },
                          "white": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "White",
                            "value": "white"
                          },
                          "seashell": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Seashell",
                            "value": "seashell"
                          },
                          "mocassin": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Mocassin",
                            "value": "mocassin"
                          },
                          "claret": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Claret",
                            "value": "claret"
                          },
                          "black": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Black",
                            "value": "black"
                          },
                          "gem": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Gem",
                            "value": "gem"
                          }
                        }
                      },
                      "quotationMarksEnabled": {
                        "jcr:primaryType": "nt:unstructured",
                        "uncheckedValue": "false",
                        "name": "./quotationMarksEnabled",
                        "text": "Enable quotation marks",
                        "value": "true",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox"
                      }
                    }
                  }
                }
              }
            }
          },
          "id-tab": {
            "jcr:primaryType": "nt:unstructured",
            "path": "/apps/demo-site-a/components/dialog/id-tab/cq:dialog/content/items/tabs/items/id-tab",
            "sling:resourceType": "granite/ui/components/foundation/include"
          }
        }
      }
    }
  }
}
