{
  "jcr:primaryType": "cq:Component",
  "cq:dialog": {
    "sling:resourceType": "cq/gui/components/authoring/dialog",
    "jcr:primaryType": "nt:unstructured",
    "jcr:title": "Accordion",
    "trackingFeature": "core-components:accordion:v1",
    "helpPath": "https://www.adobe.com/go/aem_cmp_accordion_v1",
    "extraClientlibs": [
      "Demo Heading D",
      "core.wcm.components.accordion.v1.editor",
      "Demo Heading C"
    ],
    "content": {
      "jcr:primaryType": "nt:unstructured",
      "granite:class": "cmp-accordion__editor",
      "items": {
        "jcr:primaryType": "nt:unstructured",
        "tabs": {
          "jcr:primaryType": "nt:unstructured",
          "items": {
            "jcr:primaryType": "nt:unstructured",
            "content": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:title": "Content",
              "maximized": true,
              "sling:orderBefore": "properties",
              "sling:resourceType": "granite/ui/components/coral/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "columns": {
                  "jcr:primaryType": "nt:unstructured",
                  "margin": true,
                  "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "column": {
                      "jcr:primaryType": "nt:unstructured",
                      "sling:resourceType": "granite/ui/components/coral/foundation/container",
                      "items": {
                        "jcr:primaryType": "nt:unstructured",
                        "sling:hideChildren": [],
                        "icon": {
                          "jcr:primaryType": "nt:unstructured",
                          "composite": true,
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/multifield",
                          "field": {
                            "jcr:primaryType": "nt:unstructured",
                            "name": "./icon",
                            "sling:resourceType": "granite/ui/components/coral/foundation/container",
                            "items": {
                              "jcr:primaryType": "nt:unstructured",
                              "accordionNumber": {
                                "jcr:primaryType": "nt:unstructured",
                                "required": true,
                                "min": "1",
                                "name": "./accordionNumber",
                                "fieldLabel": "Accordion Number",
                                "sling:resourceType": "granite/ui/components/coral/foundation/form/numberfield",
                                "fieldDescription": "Which accordion should icon apply to?"
                              },
                              "iconId": {
                                "jcr:primaryType": "nt:unstructured",
                                "svgPath": "Demo Heading H",
                                "emptyText": "Select an Icon",
                                "required": true,
                                "name": "./iconId",
                                "value": "no-icon",
                                "fieldLabel": "Icon ID",
                                "sling:resourceType": "/apps/demo/components/commons/authoring/iconSelect/v1/iconSelect",
                                "fieldDescription": "The icon to render on tab. "
                              },
                              "label": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "./label",
                                "fieldLabel": "Aria Label",
                                "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                                "fieldDescription": "Quis autem vel eum iure reprehenderit qui in ea voluptate velit."
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "theme": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:title": "Theme",
              "sling:orderBefore": "properties",
              "sling:resourceType": "granite/ui/components/coral/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "columns": {
                  "jcr:primaryType": "nt:unstructured",
                  "margin": true,
                  "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "column": {
                      "jcr:primaryType": "nt:unstructured",
                      "sling:resourceType": "granite/ui/components/coral/foundation/container",
                      "items": {
                        "jcr:primaryType": "nt:unstructured",
                        "sling:hideChildren": [],
                        "isInverse": {
                          "jcr:primaryType": "nt:unstructured",
                          "uncheckedValue": false,
                          "name": "./isInverse",
                          "text": "Inverse color style",
                          "value": true,
                          "checked": false,
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox",
                          "fieldDescription": "Demo Heading C"
                        },
                        "isSplit": {
                          "jcr:primaryType": "nt:unstructured",
                          "uncheckedValue": false,
                          "name": "./isSplit",
                          "text": "Split into two columns",
                          "value": true,
                          "checked": false,
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox",
                          "fieldDescription": "Demo Heading D"
                        },
                        "hasDivider": {
                          "jcr:primaryType": "nt:unstructured",
                          "uncheckedValue": false,
                          "name": "./hasDivider",
                          "text": "Add Divider",
                          "value": true,
                          "checked": false,
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox",
                          "fieldDescription": "Demo Heading B"
                        }
                      }
                    }
                  }
                }
              }
            },
            "cq:include": {
              "jcr:primaryType": "nt:unstructured",
              "path": "/mnt/overlay/demo/components/commons/permission/permission/cq:dialog/permission",
              "sling:resourceType": "granite/ui/components/coral/foundation/include"
            }
          }
        }
      }
    }
  }
}
