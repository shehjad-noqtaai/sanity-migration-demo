                              "fieldDescription": "Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet."
                            },
                            "icon": {
                              "jcr:primaryType": "nt:unstructured",
                              "svgPath": "Demo Heading H",
                              "name": "./icon",
                              "value": "no-icon",
                              "fieldLabel": "Icon",
                              "sling:resourceType": "/apps/demo/components/commons/authoring/iconSelect/v1/iconSelect",
                              "fieldDescription": "Select an icon to display."
                            },
                            "target": {
                              "jcr:primaryType": "nt:unstructured",
                              "uncheckedValue": "_self",
                              "name": "./linkTarget",
                              "text": "Open link in new tab",
                              "value": "_blank",
                              "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox",
                              "fieldDescription": "Demo Heading H"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
