                    "name": "./resisSticky",
                    "value": true,
                    "fieldLabel": "Navigation is Sticky",
                    "checked": false,
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/switch",
                    "fieldDescription": "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
