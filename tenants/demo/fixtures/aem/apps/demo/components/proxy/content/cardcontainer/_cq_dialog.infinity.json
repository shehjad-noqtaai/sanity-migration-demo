{
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Card Container",
  "helpPath": "",
  "extraClientlibs": [
    "Demo Heading E"
  ],
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "granite:class": "cmp-container__editor",
    "sling:resourceType": "granite/ui/components/coral/foundation/container",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "tabs": {
        "jcr:primaryType": "nt:unstructured",
        "maximized": true,
        "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "sling:hideChildren": "properties",
          "display": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Display",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "gridType": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./gridType",
                        "fieldLabel": "Grid type:",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                        "fieldDescription": "Demo Heading G",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "custom": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Custom",
                            "value": "custom",
                            "selected": true
                          },
                          "fixed": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Fixed",
                            "value": "fixed"
                          }
                        },
                        "granite:data": {
                          "jcr:primaryType": "nt:unstructured",
                          "acs-cq-dialog-dropdown-checkbox-showhide-target": ".gridType-showhide-target",
                          "acs-cq-dialog-dropdown-checkbox-showhide": ""
                        }
                      },
                      "CustomColumns": {
                        "jcr:primaryType": "nt:unstructured",
                        "granite:class": "gridType-showhide-target",
                        "sling:resourceType": "granite/ui/components/coral/foundation/well",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "mobileordefault": {
                            "jcr:primaryType": "nt:unstructured",
                            "max": "2",
                            "min": "1",
                            "name": "./mobileColumn",
                            "step": "1",
                            "value": "1",
                            "fieldLabel": "Mobile/Default columns:",
                            "sling:resourceType": "granite/ui/components/coral/foundation/form/numberfield",
                            "fieldDescription": "Demo Heading H"
                          },
                          "tablet": {
                            "jcr:primaryType": "nt:unstructured",
                            "max": "8",
                            "min": "1",
                            "name": "./tabletColumn",
                            "step": "1",
                            "fieldLabel": "Tablet columns:",
                            "sling:resourceType": "granite/ui/components/coral/foundation/form/numberfield",
                            "fieldDescription": "Praesent feugiat tellus eget velit fringilla, nec vehicula nisi vulputate."
                          },
                          "desktop": {
                            "jcr:primaryType": "nt:unstructured",
                            "max": "12",
                            "min": "1",
                            "name": "./desktopColumn",
                            "step": "1",
                            "fieldLabel": "Desktop columns:",
                            "sling:resourceType": "granite/ui/components/coral/foundation/form/numberfield",
                            "fieldDescription": "Temporibus autem quibusdam et aut officiis debitis aut rerum."
                          }
                        },
                        "granite:data": {
                          "jcr:primaryType": "nt:unstructured",
                          "acs-dropdownshowhidetargetvalue": "custom"
                        }
                      },
                      "FixedColumns": {
                        "jcr:primaryType": "nt:unstructured",
                        "granite:class": "gridType-showhide-target",
                        "sling:resourceType": "granite/ui/components/coral/foundation/well",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "fixedLayoutDropdown": {
                            "jcr:primaryType": "nt:unstructured",
                            "name": "./fixedLayoutDropdown",
                            "fieldLabel": "Fixed grid type:",
                            "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                            "fieldDescription": "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
                            "items": {
                              "jcr:primaryType": "nt:unstructured",
                              "layout2080": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "20/80",
                                "text": "20/80",
                                "value": "1fr 4fr"
                              },
                              "layout3070": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "30/70",
                                "text": "30/70",
                                "value": "3fr 7fr"
                              },
                              "layout4060": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "40/60",
                                "text": "40/60",
                                "value": "2fr 3fr"
                              },
                              "layout6040": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "60/40",
                                "text": "60/40",
                                "value": "3fr 2fr"
                              },
                              "layout7030": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "70/30",
                                "text": "70/30",
                                "value": "7fr 3fr"
                              },
                              "layout8020": {
                                "jcr:primaryType": "nt:unstructured",
                                "name": "80/20",
                                "text": "80/20",
                                "value": "4fr 1fr"
                              }
                            }
                          }
                        },
                        "granite:data": {
                          "jcr:primaryType": "nt:unstructured",
                          "acs-dropdownshowhidetargetvalue": "fixed"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "spacing": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Spacing",
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "gutter": {
                        "jcr:primaryType": "nt:unstructured",
                        "path": "/apps/demo/components/commons/spacing/v1/dialogs/wellSpacing",
                        "sling:resourceType": "granite/ui/components/coral/foundation/include"
                      }
                    }
                  }
                }
              }
            }
          },
          "backgroundColor": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Background Color",
            "sling:orderBefore": "cq:include",
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "backgroundColor": {
                        "jcr:primaryType": "nt:unstructured",
                        "path": "/apps/demo/components/commons/backgroundstyle/v1/dialogs/wellColorBackground",
                        "sling:resourceType": "granite/ui/components/coral/foundation/include"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
