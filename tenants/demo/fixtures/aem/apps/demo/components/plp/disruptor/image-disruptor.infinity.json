{
  "jcr:primaryType": "cq:Component",
  "cq:dialog": {
    "jcr:primaryType": "nt:unstructured",
    "jcr:title": "Image disruptor\n",
    "sling:resourceType": "cq/gui/components/authoring/dialog",
    "content": {
      "jcr:primaryType": "nt:unstructured",
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "jcr:primaryType": "nt:unstructured",
        "tabs": {
          "jcr:primaryType": "nt:unstructured",
          "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
          "items": {
            "jcr:primaryType": "nt:unstructured",
            "image": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:title": "Image",
              "margin": true,
              "sling:resourceType": "granite/ui/components/coral/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "columns": {
                  "jcr:primaryType": "nt:unstructured",
                  "margin": true,
                  "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "column": {
                      "jcr:primaryType": "nt:unstructured",
                      "sling:resourceType": "granite/ui/components/coral/foundation/container",
                      "items": {
                        "jcr:primaryType": "nt:unstructured",
                        "include": {
                          "jcr:primaryType": "nt:unstructured",
                          "path": "/apps/demo/components/common/demo-image/cq:dialog/content/items/tabs/items/image/items/columns/items/column",
                          "sling:resourceType": "granite/ui/components/coral/foundation/include"
                        }
                      }
                    }
                  }
                }
              }
            },
            "properties": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:title": "Properties",
              "margin": true,
              "sling:resourceType": "granite/ui/components/coral/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "columns": {
                  "jcr:primaryType": "nt:unstructured",
                  "margin": true,
                  "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "column": {
                      "jcr:primaryType": "nt:unstructured",
                      "sling:resourceType": "granite/ui/components/coral/foundation/container",
                      "items": {
                        "jcr:primaryType": "nt:unstructured",
                        "title": {
                          "jcr:primaryType": "nt:unstructured",
                          "name": "./title",
                          "fieldLabel": "Title",
                          "sling:resourceType": "granite/ui/components/foundation/form/textfield",
                          "fieldDescription": [
                            "Title"
                          ]
                        },
                        "backdrop": {
                          "jcr:primaryType": "nt:unstructured",
                          "name": "./backdropSelection",
                          "fieldLabel": "Backdrop",
                          "sling:resourceType": "granite/ui/components/foundation/form/select",
                          "items": {
                            "jcr:primaryType": "nt:unstructured",
                            "noBackdrop": {
                              "jcr:primaryType": "nt:unstructured",
                              "text": "No Backdrop",
                              "value": ""
                            },
                            "fullBackdrop": {
                              "jcr:primaryType": "nt:unstructured",
                              "text": "Full Backdrop",
                              "value": "component-backdrop--full"
                            },
                            "halfBackdrop": {
                              "jcr:primaryType": "nt:unstructured",
                              "text": "Half Backdrop",
                              "value": "component-backdrop--half"
                            },
                            "offsetBackdrop": {
                              "jcr:primaryType": "nt:unstructured",
                              "text": "Offset Backdrop",
                              "value": "component-backdrop--offset"
                            },
                            "overlapBackdrop": {
                              "jcr:primaryType": "nt:unstructured",
                              "text": "Overlap Backdrop",
                              "value": "component-backdrop--overlap"
                            }
                          }
                        },
                        "scriptText": {
                          "jcr:primaryType": "nt:unstructured",
                          "name": "./scriptText",
                          "fieldLabel": "Script Text",
                          "sling:resourceType": "granite/ui/components/foundation/form/textfield",
                          "fieldDescription": [
                            "Script Text"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            },
            "product": {
              "jcr:primaryType": "nt:unstructured",
              "jcr:title": "ProductPath",
              "required": true,
              "name": "./productPath",
              "selectionId": "sku",
              "fieldLabel": "Select Product ",
              "eaem-show-on-collapse": "EAEM.showProductName",
              "sling:resourceType": "/libs/commerce/gui/components/common/cifproductfield",
              "fieldDescription": "Magento Product Path"
            }
          }
        }
      }
    }
  }
}
