{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Image",
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "tabs": {
        "jcr:primaryType": "nt:unstructured",
        "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "asset": {
            "jcr:primaryType": "nt:unstructured",
            "sling:hideResource": "true"
          },
          "metadata": {
            "jcr:primaryType": "nt:unstructured",
            "sling:hideResource": "true"
          },
          "image": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Image",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "include": {
                        "jcr:primaryType": "nt:unstructured",
                        "path": "/apps/demo/components/common/demo-image/cq:dialog/content/items/tabs/items/image/items/columns/items/column",
                        "sling:resourceType": "granite/ui/components/coral/foundation/include"
                      }
                    }
                  }
                }
              }
            }
          },
          "additional-adjustements": {
            "jcr:primaryType": "nt:unstructured",
            "cq:showOnCreate": true,
            "jcr:title": "Variations",
            "sling:orderBefore": "commerce",
            "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "column": {
                "jcr:primaryType": "nt:unstructured",
                "sling:resourceType": "granite/ui/components/coral/foundation/container",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "classVariation": {
                    "jcr:primaryType": "nt:unstructured",
                    "name": "./classVariation",
                    "fieldLabel": "Class Variation",
                    "sling:resourceType": "granite/ui/components/foundation/form/select",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "fullWidth": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Full Width",
                        "value": "media-ratio--full-width-image"
                      },
                      "halfHeight": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Half Height",
                        "value": "media-ratio--half-height-image"
                      },
                      "halfWidth": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Half Width",
                        "value": "media-ratio--half-width-image"
                      }
                    }
                  },
                  "imageAlignment": {
                    "jcr:primaryType": "nt:unstructured",
                    "name": "./imageAlignment",
                    "fieldLabel": "Image Alignment",
                    "sling:resourceType": "granite/ui/components/foundation/form/select",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "left": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Left",
                        "value": "start"
                      },
                      "center": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Center",
                        "value": "center"
                      },
                      "right": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Right",
                        "value": "end"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
