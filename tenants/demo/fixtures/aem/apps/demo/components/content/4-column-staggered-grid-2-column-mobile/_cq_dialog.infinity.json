{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "4 Column Staggered Grid 2 Column Mobile",
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "column": {
        "jcr:primaryType": "nt:unstructured",
        "sling:resourceType": "granite/ui/components/foundation/container",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "heading": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./heading",
            "fieldLabel": "Header",
            "sling:resourceType": "granite/ui/components/foundation/form/textfield",
            "fieldDescription": [
              "style heading"
            ]
          },
          "backdrop": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./backdropSelection",
            "fieldLabel": "Backdrop",
            "sling:resourceType": "granite/ui/components/foundation/form/select",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "noBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "No Backdrop",
                "value": ""
              },
              "fullBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Full Backdrop",
                "value": "component-backdrop--full"
              },
              "halfBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Half Backdrop",
                "value": "component-backdrop--half"
              },
              "offsetBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Offset Backdrop",
                "value": "component-backdrop--offset"
              },
              "overlapBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Overlap Backdrop",
                "value": "component-backdrop--overlap"
              },
              "offsetMidRightBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Offset Mid Right Backdrop",
                "value": "component-backdrop__offset--mid-right"
              }
            }
          },
          "scriptTitle": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./scriptTitle",
            "fieldLabel": "Script Title",
            "sling:resourceType": "granite/ui/components/foundation/form/textfield",
            "fieldDescription": [
              "Optional field "
            ]
          },
          "imageDisplay": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./imageDisplay",
            "fieldLabel": "Image Display",
            "sling:resourceType": "granite/ui/components/foundation/form/select",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "inline": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Inline",
                "value": "staggered-grid--inline"
              },
              "staggered": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Staggered",
                "value": ""
              }
            }
          },
          "headerMargin": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./headerMargin",
            "value": "header-margin--base",
            "fieldLabel": "Header Margin",
            "sling:resourceType": "granite/ui/components/foundation/form/select",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "defaultMargin": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Default Margin",
                "value": "header-margin--base"
              },
              "lessMargin": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Less Margin",
                "value": "header-margin--tight"
              },
              "moreMargin": {
                "jcr:primaryType": "nt:unstructured",
                "text": "More Margin",
                "value": "header-margin--loose"
              }
            }
          },
          "multi": {
            "jcr:primaryType": "nt:unstructured",
            "composite": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/form/multifield",
            "fieldDescription": "what is your style",
            "field": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "name": "./styleimage",
              "sling:resourceType": "granite/ui/components/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "column": {
                  "jcr:primaryType": "nt:unstructured",
                  "sling:resourceType": "granite/ui/components/foundation/container",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "mobileImage": {
                      "jcr:primaryType": "nt:unstructured",
                      "rootpath": "/content/dam",
                      "name": "./styleimagemobile",
                      "fieldLabel": "Mobile Image",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser"
                    },
                    "desktopImage": {
                      "jcr:primaryType": "nt:unstructured",
                      "rootpath": "/content/dam",
                      "name": "./styleimagedesktop",
                      "fieldLabel": "desktop Image",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser"
                    },
                    "imageAltText": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./imageAltText",
                      "fieldLabel": "Image ALT Text",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                      "fieldDescription": "Image ALT Text"
                    },
                    "imageTitle": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./imageTitle",
                      "fieldLabel": "Image Title",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                      "fieldDescription": "Image Title"
                    },
                    "ctaText": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./ctaText",
                      "fieldLabel": "CTA Text",
                      "sling:resourceType": "granite/ui/components/foundation/form/textfield",
                      "fieldDescription": "what is your style"
                    },
                    "ctaCategoryPath": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./ctaCategoryPath",
                      "selectionId": "path",
                      "fieldLabel": "PLP Path",
                      "eaem-show-on-collapse": "EAEM.showProductName",
                      "sling:resourceType": "/libs/commerce/gui/components/common/cifcategoryfield",
                      "fieldDescription": "Choose the PLP Page Path"
                    },
                    "ctaProductPath": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./ctaProductPath",
                      "selectionId": "slug",
                      "fieldLabel": "Product Path",
                      "eaem-show-on-collapse": "EAEM.showProductName",
                      "sling:resourceType": "/libs/commerce/gui/components/common/cifproductfield",
                      "fieldDescription": "Choose the PDP Page Path"
                    },
                    "ctaLink": {
                      "jcr:primaryType": "nt:unstructured",
                      "rootPath": "/content/demo",
                      "name": "./ctaLink",
                      "fieldLabel": "CTA Link",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser",
                      "fieldDescription": "redirectionlink"
                    },
                    "linkType": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./linkType",
                      "value": "link-primary--no-underline",
                      "fieldLabel": "Link Type",
                      "sling:resourceType": "granite/ui/components/foundation/form/select",
                      "fieldDescription": "Demo Heading C",
                      "items": {
                        "jcr:primaryType": "nt:unstructured",
                        "noUnderline": {
                          "jcr:primaryType": "nt:unstructured",
                          "text": "No Underline",
                          "value": "link-primary--no-underline"
                        },
                        "withUnderline": {
                          "jcr:primaryType": "nt:unstructured",
                          "text": "With Underline",
                          "value": "link-primary"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
