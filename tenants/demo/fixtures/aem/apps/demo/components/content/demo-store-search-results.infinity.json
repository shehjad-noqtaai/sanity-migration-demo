              "fieldDescription": "Google Maps Key"
            },
            "storeListURL": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "rootPath": "/content",
              "name": "./storeListURL",
              "fieldLabel": "Store List Page",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
              "fieldDescription": "Demo Heading C"
            },
            "appointmentsURL": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "rootPath": "/content",
              "name": "./appointmentsURL",
              "fieldLabel": "Appointments Page",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
              "fieldDescription": "Demo Heading C"
            },
            "storeDetailsURL": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "rootPath": "/content",
              "name": "./storeDetailsURL",
              "fieldLabel": "Store Details Page",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
              "fieldDescription": "Demo Heading D"
            }
          }
        }
      }
