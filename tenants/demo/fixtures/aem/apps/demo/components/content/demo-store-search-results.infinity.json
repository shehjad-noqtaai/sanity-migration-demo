    "content": {
      "jcr:primaryType": "nt:unstructured",
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "jcr:primaryType": "nt:unstructured",
        "column": {
          "jcr:primaryType": "nt:unstructured",
          "sling:resourceType": "granite/ui/components/coral/foundation/container",
          "items": {
            "jcr:primaryType": "nt:unstructured",
            "heading": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "name": "./heading",
              "fieldLabel": "Title Header",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
              "fieldDescription": "Store Locator Header"
            },
            "seoText": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "name": "./seoText",
              "fieldLabel": "Store Locator Seo Text",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
              "fieldDescription": "Store Locator Seo Text"
            },
            "subHeading": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "name": "./subHeading",
              "fieldLabel": "Sub heading",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
              "fieldDescription": "Store Locator Header sub heading"
            },
            "googleMapsKey": {
              "jcr:primaryType": "nt:unstructured",
              "required": true,
              "name": "./googleMapsKey",
              "fieldLabel": "google maps key",
