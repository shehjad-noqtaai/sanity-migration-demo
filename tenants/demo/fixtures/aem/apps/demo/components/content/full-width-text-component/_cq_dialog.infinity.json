{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Full Width Text Overlay",
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "column": {
        "jcr:primaryType": "nt:unstructured",
        "sling:resourceType": "granite/ui/components/coral/foundation/container",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "title": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./title",
            "fieldLabel": "Title",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
            "fieldDescription": "Title"
          },
          "desktopImage": {
            "jcr:primaryType": "nt:unstructured",
            "rootPath": "/content",
            "name": "./desktopImage",
            "fieldLabel": "Desktop Image",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser",
            "fieldDescription": "Give Desktop Image"
          },
          "mobileImage": {
            "jcr:primaryType": "nt:unstructured",
            "rootPath": "/content",
            "name": "./mobileImage",
            "fieldLabel": "Mobile Image",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser",
            "fieldDescription": "Give Mobile Image"
          },
          "scriptTitle": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./scriptTitle",
            "fieldLabel": "Script Title",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
            "fieldDescription": "Script Title"
          },
          "ctaText": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./ctaText",
            "fieldLabel": "Cta Text",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
            "fieldDescription": "Give Cta Text"
          },
          "ctaCategoryPath": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./ctaCategoryPath",
            "selectionId": "path",
            "fieldLabel": "PLP Path",
            "eaem-show-on-collapse": "EAEM.showProductName",
            "sling:resourceType": "/libs/commerce/gui/components/common/cifcategoryfield",
            "fieldDescription": "Choose the PLP Page Path"
          },
          "ctaProductPath": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./ctaProductPath",
            "selectionId": "slug",
            "fieldLabel": "Product Path",
            "eaem-show-on-collapse": "EAEM.showProductName",
            "sling:resourceType": "/libs/commerce/gui/components/common/cifproductfield",
            "fieldDescription": "Choose the PDP Page Path"
          },
          "ctaLink": {
            "jcr:primaryType": "nt:unstructured",
            "rootPath": "/content/demo",
            "name": "./ctaLink",
            "fieldLabel": "Cta Link",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser",
            "fieldDescription": "Give Cta Link"
          },
          "altText": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./altText",
            "fieldLabel": "Alt Text",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield"
          },
          "titleTag": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./titleTag",
            "fieldLabel": "Title Tag",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
            "fieldDescription": "Tag to display when hover over the link"
          },
          "copyText": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./copyText",
            "fieldLabel": "Copy Text",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
            "fieldDescription": "Copy Text"
          },
          "backdrop": {
            "jcr:primaryType": "nt:unstructured",
            "name": "./backdropSelection",
            "fieldLabel": "Backdrop",
            "sling:resourceType": "granite/ui/components/foundation/form/select",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "noBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "No Backdrop",
                "value": ""
              },
              "fullBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Full Backdrop",
                "value": "component-backdrop--full"
              },
              "halfBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Half Backdrop",
                "value": "component-backdrop--half"
              },
              "offsetBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Offset Backdrop",
                "value": "component-backdrop--offset"
              },
              "overlapBackdrop": {
                "jcr:primaryType": "nt:unstructured",
                "text": "Overlap Backdrop",
                "value": "component-backdrop--overlap"
              }
            }
          }
        }
      }
    }
  }
}
