{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Product Recommendation Carousel",
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/container",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "tabs": {
        "jcr:primaryType": "nt:unstructured",
        "maximized": true,
        "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "properties": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Select the Best Selling products",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/container",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "columns": {
                "jcr:primaryType": "nt:unstructured",
                "margin": true,
                "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "column": {
                    "jcr:primaryType": "nt:unstructured",
                    "sling:resourceType": "granite/ui/components/coral/foundation/container",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "handWrittenHeader": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./handWrittenHeader",
                        "fieldLabel": "Hand Written Header",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                        "fieldDescription": "Demo Heading H"
                      },
                      "header": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./header",
                        "fieldLabel": "Header",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                        "fieldDescription": "Product recommendations Header"
                      },
                      "backdrop": {
                        "jcr:primaryType": "nt:unstructured",
                        "name": "./backdropSelection",
                        "fieldLabel": "Backdrop",
                        "sling:resourceType": "granite/ui/components/foundation/form/select",
                        "items": {
                          "jcr:primaryType": "nt:unstructured",
                          "noBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "No Backdrop",
                            "value": ""
                          },
                          "fullBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Full Backdrop",
                            "value": "component-backdrop--full"
                          },
                          "halfBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Half Backdrop",
                            "value": "component-backdrop--half"
                          },
                          "offsetBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Offset Backdrop",
                            "value": "component-backdrop--offset"
                          },
                          "overlapBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Overlap Backdrop",
                            "value": "component-backdrop--overlap"
                          },
                          "offsetRightBackdrop": {
                            "jcr:primaryType": "nt:unstructured",
                            "text": "Offset Right Backdrop",
                            "value": "component-backdrop__offset--right"
                          }
                        }
                      },
                      "imageMulti": {
                        "jcr:primaryType": "nt:unstructured",
                        "eaem-min-items": "5",
                        "composite": true,
                        "fieldLabel": "Select Products",
                        "sling:resourceType": "granite/ui/components/coral/foundation/form/multifield",
                        "eaem-max-items": "15",
                        "field": {
                          "jcr:primaryType": "nt:unstructured",
                          "name": "./products",
                          "sling:resourceType": "granite/ui/components/coral/foundation/container",
                          "items": {
                            "jcr:primaryType": "nt:unstructured",
                            "column": {
                              "jcr:primaryType": "nt:unstructured",
                              "sling:resourceType": "granite/ui/components/coral/foundation/container",
                              "items": {
                                "jcr:primaryType": "nt:unstructured",
                                "title": {
                                  "jcr:primaryType": "nt:unstructured",
                                  "name": "./productPath",
                                  "selectionId": "sku",
                                  "fieldLabel": "Select Product ",
                                  "eaem-show-on-collapse": "EAEM.showProductName",
                                  "sling:resourceType": "/libs/commerce/gui/components/common/cifproductfield",
                                  "fieldDescription": "Magento Product Path"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
