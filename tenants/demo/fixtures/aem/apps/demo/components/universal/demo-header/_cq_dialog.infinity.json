{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Header",
  "sling:resourceType": "cq/gui/components/authoring/dialog",
  "content": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "granite/ui/components/coral/foundation/container",
    "items": {
      "jcr:primaryType": "nt:unstructured",
      "tabs": {
        "jcr:primaryType": "nt:unstructured",
        "maximized": true,
        "sling:resourceType": "granite/ui/components/coral/foundation/tabs",
        "items": {
          "jcr:primaryType": "nt:unstructured",
          "general": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "General",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "column": {
                "jcr:primaryType": "nt:unstructured",
                "sling:resourceType": "granite/ui/components/coral/foundation/container",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "logoPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./logoPath",
                    "fieldLabel": "Logo Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Demo Heading B"
                  }
                }
              }
            }
          },
          "iconTab": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Icon Tab",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "column": {
                "jcr:primaryType": "nt:unstructured",
                "sling:resourceType": "granite/ui/components/coral/foundation/container",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "hideSearch": {
                    "jcr:primaryType": "nt:unstructured",
                    "uncheckedValue": "false",
                    "name": "./hideSearch",
                    "text": "Hide Search",
                    "value": "true",
                    "fieldLabel": "Hide Search",
                    "checked": false,
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/checkbox",
                    "fieldDescription": "Button to disable Search"
                  },
                  "helpIconPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./helpPath",
                    "fieldLabel": "Help Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Please provide path to the Help Page"
                  },
                  "storeLocatorIconPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./storeLocatorPath",
                    "fieldLabel": "Store Locator Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Demo Heading E"
                  },
                  "appointmentIconPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./appointmentPath",
                    "fieldLabel": "Appointment Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Demo Heading E"
                  },
                  "favouriteIconPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./favouritePath",
                    "fieldLabel": "Favourite Icon Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Demo Heading F"
                  },
                  "userPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./userPath",
                    "fieldLabel": "User Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Please provide path to the User Page"
                  },
                  "searchPath": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content",
                    "name": "./searchPath",
                    "fieldLabel": "Search Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                    "fieldDescription": "Please provide path to the User Page"
                  }
                }
              }
            }
          },
          "navigationTab": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Navigation",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "column": {
                "jcr:primaryType": "nt:unstructured",
                "sling:resourceType": "granite/ui/components/coral/foundation/container",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "navigationExperienceFragment": {
                    "jcr:primaryType": "nt:unstructured",
                    "rootPath": "/content/experience-fragments/demo",
                    "name": "./navigationPath",
                    "fieldLabel": "Navigation Path",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathbrowser",
                    "fieldDescription": "Experience Fragment Navigation Path "
                  }
                }
              }
            }
          },
          "welcomeMessage": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "Welcome Message",
            "margin": true,
            "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
            "items": {
              "jcr:primaryType": "nt:unstructured",
              "column": {
                "jcr:primaryType": "nt:unstructured",
                "sling:resourceType": "granite/ui/components/coral/foundation/container",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "rteDesc": {
                    "jcr:primaryType": "nt:unstructured",
                    "name": "./customisedText",
                    "sling:resourceType": "cq/gui/components/authoring/dialog/richtext",
                    "useFixedInlineToolbar": true,
                    "rtePlugins": {
                      "jcr:primaryType": "nt:unstructured",
                      "format": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "links": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "justify": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "lists": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "paraformat": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "image": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "subsuperscript": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "spellcheck": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      },
                      "misctools": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*",
                        "specialCharsConfig": {
                          "jcr:primaryType": "nt:unstructured",
                          "chars": {
                            "jcr:primaryType": "nt:unstructured",
                            "copyright": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#169;"
                            },
                            "trademark": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#8482;"
                            },
                            "registered": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#174;"
                            },
                            "emDash": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#8212;"
                            },
                            "pound": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#163;"
                            },
                            "nbsp": {
                              "jcr:primaryType": "nt:unstructured",
                              "entity": "&#160;"
                            }
                          }
                        }
                      },
                      "table": {
                        "jcr:primaryType": "nt:unstructured",
                        "features": "*"
                      }
                    },
                    "uiSettings": {
                      "jcr:primaryType": "nt:unstructured",
                      "cui": {
                        "jcr:primaryType": "nt:unstructured",
                        "inline": {
                          "jcr:primaryType": "nt:unstructured",
                          "toolbar": [
                            "format#bold",
                            "format#italic",
                            "format#underline",
                            "#justify",
                            "#lists",
                            "subsuperscript#subscript",
                            "subsuperscript#superscript",
                            "links#modifylink",
                            "links#unlink",
                            "links#anchor",
                            "#image",
                            "findreplace#find",
                            "findreplace#replace",
                            "spellcheck#checktext",
                            "misctools#specialchars",
                            "misctools#sourceedit",
                            "#styles",
                            "#paraformat",
                            "table#table"
                          ],
                          "popovers": {
                            "jcr:primaryType": "nt:unstructured",
                            "justify": {
                              "jcr:primaryType": "nt:unstructured",
                              "ref": "justify",
                              "items": [
                                "justify#justifyleft",
                                "justify#justifycenter",
                                "justify#justifyright"
                              ]
                            },
                            "lists": {
                              "jcr:primaryType": "nt:unstructured",
                              "ref": "lists",
                              "items": [
                                "lists#unordered",
                                "lists#ordered",
                                "lists#outdent",
                                "lists#indent"
                              ]
                            },
                            "paraformat": {
                              "jcr:primaryType": "nt:unstructured",
                              "ref": "paraformat",
                              "items": "paraformat:getFormats:paraformat-pulldown"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "hamburgerdetails": {
            "jcr:primaryType": "nt:unstructured",
            "jcr:title": "FooterHamburgerDetails",
            "composite": true,
            "fieldLabel": "HamburgerDetails",
            "sling:resourceType": "granite/ui/components/coral/foundation/form/multifield",
            "field": {
              "jcr:primaryType": "nt:unstructured",
              "name": "./hamburgerDetails",
              "sling:resourceType": "granite/ui/components/coral/foundation/container",
              "items": {
                "jcr:primaryType": "nt:unstructured",
                "column": {
                  "jcr:primaryType": "nt:unstructured",
                  "sling:resourceType": "granite/ui/components/coral/foundation/container",
                  "items": {
                    "jcr:primaryType": "nt:unstructured",
                    "title": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./title",
                      "fieldLabel": "Hamburger link title",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                      "fieldDescription": "Enter Hamburger link title"
                    },
                    "ctaCategoryPath": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./ctaCategoryPath",
                      "selectionId": "path",
                      "fieldLabel": "PLP Path",
                      "eaem-show-on-collapse": "EAEM.showProductName",
                      "sling:resourceType": "/libs/commerce/gui/components/common/cifcategoryfield",
                      "fieldDescription": "Choose the PLP Page Path"
                    },
                    "ctaProductPath": {
                      "jcr:primaryType": "nt:unstructured",
                      "name": "./ctaProductPath",
                      "selectionId": "slug",
                      "fieldLabel": "Product Path",
                      "eaem-show-on-collapse": "EAEM.showProductName",
                      "sling:resourceType": "/libs/commerce/gui/components/common/cifproductfield",
                      "fieldDescription": "Choose the PDP Page Path"
                    },
                    "link": {
                      "jcr:primaryType": "nt:unstructured",
                      "rootPath": "/content/demo",
                      "name": "./link",
                      "fieldLabel": "Hamburger link",
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                      "fieldDescription": "Enter Hamburger link"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
