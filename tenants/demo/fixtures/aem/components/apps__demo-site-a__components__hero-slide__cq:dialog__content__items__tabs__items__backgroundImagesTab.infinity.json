{
  "jcr:primaryType": "nt:unstructured",
  "jcr:title": "Background",
  "margin": true,
  "sling:resourceType": "granite/ui/components/coral/foundation/container",
  "items": {
    "jcr:primaryType": "nt:unstructured",
    "columns": {
      "jcr:primaryType": "nt:unstructured",
      "margin": true,
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "jcr:primaryType": "nt:unstructured",
        "column": {
          "jcr:primaryType": "nt:unstructured",
          "sling:resourceType": "granite/ui/components/coral/foundation/container",
          "items": {
            "jcr:primaryType": "nt:unstructured",
            "asset-allowed-heading": {
              "jcr:primaryType": "nt:unstructured",
              "text": "Praesent feugiat tellus eget velit fringilla, nec vehicula nisi vulputate.",
              "level": "2",
              "sling:resourceType": "granite/ui/components/foundation/heading"
            },
            "images": {
              "jcr:primaryType": "nt:unstructured",
              "composite": "true",
              "fieldLabel": "Background images",
              "sling:resourceType": "granite/ui/components/coral/foundation/form/multifield",
              "field": {
                "jcr:primaryType": "nt:unstructured",
                "jcr:title": "Image options",
                "name": "./bgImages",
                "sling:resourceType": "granite/ui/components/coral/foundation/form/fieldset",
                "items": {
                  "jcr:primaryType": "nt:unstructured",
                  "background-image": {
                    "jcr:primaryType": "nt:unstructured",
                    "fileReferenceParameter": "./fileReference",
                    "required": true,
                    "useHTML5": false,
                    "mimeTypes": [
                      "image/gif",
                      "image/jpeg",
                      "image/webp",
                      "image/tiff",
                      "image/svg+xml"
                    ],
                    "fileNameParameter": "./fileName",
                    "name": "./image",
                    "class": "cq-droptarget",
                    "disabled": false,
                    "fieldLabel": "Background Image",
                    "multiple": false,
                    "allowUpload": false,
                    "sling:resourceType": "cq/gui/components/authoring/dialog/fileupload",
                    "autoStart": false
                  },
                  "visible": {
                    "jcr:primaryType": "nt:unstructured",
                    "name": "visible",
                    "fieldLabel": "Devices",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "desktop": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "desktop",
                        "value": "desktop"
                      },
                      "xl": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "XL",
                        "value": "xl"
                      },
                      "tablet": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "tablet",
                        "value": "tablet"
                      },
                      "mobile": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "mobile",
                        "value": "mobile"
                      }
                    }
                  },
                  "alignment": {
                    "jcr:primaryType": "nt:unstructured",
                    "name": "alignment",
                    "fieldLabel": "Image alignment",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                    "items": {
                      "jcr:primaryType": "nt:unstructured",
                      "top-left": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Top left",
                        "value": "top-left"
                      },
                      "top-center": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Top center",
                        "value": "top-center"
                      },
                      "top-right": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Top right",
                        "value": "top-right"
                      },
                      "middle-left": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Middle left",
                        "value": "middle-left"
                      },
                      "middle-center": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Middle center",
                        "value": "middle-center"
                      },
                      "middle-right": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Middle right",
                        "value": "middle-right"
                      },
                      "borrom-left": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Bottom left",
                        "value": "bottom-left"
                      },
                      "borrom-center": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Bottom center",
                        "value": "bottom-center"
                      },
                      "borrom-right": {
                        "jcr:primaryType": "nt:unstructured",
                        "text": "Bottom right",
                        "value": "bottom-right"
                      }
                    }
                  },
                  "background-imageLink": {
                    "jcr:primaryType": "nt:unstructured",
                    "required": true,
                    "rootPath": "/content",
                    "name": "imageLink",
                    "fieldLabel": "Image Link",
                    "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
