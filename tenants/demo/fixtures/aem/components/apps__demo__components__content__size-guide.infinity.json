                                    "jcr:primaryType": "nt:unstructured",
                                    "ref": "justify",
                                    "items": [
                                      "justify#justifyleft",
                                      "justify#justifycenter",
                                      "justify#justifyright"
                                    ]
                                  },
                                  "lists": {
